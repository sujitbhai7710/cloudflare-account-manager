generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  sessions       Session[]
  cfAccounts     CloudflareAccount[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
}

model CloudflareAccount {
  id              String    @id @default(cuid())
  userId          String
  name            String
  email           String?
  accountId       String
  apiTokenEnc     String
  apiTokenIv      String
  isActive        Boolean   @default(true)
  lastSync        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workers      Worker[]
  databases    D1Database[]
  kvNamespaces KVNamespace[]
  r2Buckets    R2Bucket[]
  
  @@index([userId])
}

model Worker {
  id                String   @id @default(cuid())
  cfAccountId       String
  workerId          String
  name              String
  compatibilityDate String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  cfAccount CloudflareAccount @relation(fields: [cfAccountId], references: [id], onDelete: Cascade)
  
  @@unique([cfAccountId, workerId])
}

model D1Database {
  id          String   @id @default(cuid())
  cfAccountId String
  databaseId  String
  name        String
  version     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cfAccount CloudflareAccount @relation(fields: [cfAccountId], references: [id], onDelete: Cascade)
  
  @@unique([cfAccountId, databaseId])
}

model KVNamespace {
  id          String   @id @default(cuid())
  cfAccountId String
  namespaceId String
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  cfAccount CloudflareAccount @relation(fields: [cfAccountId], references: [id], onDelete: Cascade)
  
  @@unique([cfAccountId, namespaceId])
}

model R2Bucket {
  id            String    @id @default(cuid())
  cfAccountId   String
  bucketName    String
  creationDate  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  cfAccount CloudflareAccount @relation(fields: [cfAccountId], references: [id], onDelete: Cascade)
  
  @@unique([cfAccountId, bucketName])
}
